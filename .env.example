# Aplicacion
APP_NAME=Clasificador Inteligente de Documentos con IA
# Valores soportados: development | test | production
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Base de datos
# Desarrollo local con docker-compose: PostgreSQL expuesto en 127.0.0.1:5433
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5433/clasificador_documentos_ia

# Archivos
UPLOADS_DIR=uploads

# Embeddings y busqueda
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
SEMANTIC_SEARCH_TOP_K=5

# Redis y Celery
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
